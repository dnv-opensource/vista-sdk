{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "declaration": false,
        "paths": {
            "dnv-vista-sdk": ["../packages/vista-sdk/dist"],
            "dnv-vista-sdk/*": ["../packages/vista-sdk/*"]
        },
        "baseUrl": "."
    },
    "include": ["./*.ts"],
    "exclude": ["node_modules", "dist"]
}
